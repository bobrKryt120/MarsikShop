<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Source+Code+Pro:ital,wght@0,200..900;1,200..900&family=Work+Sans:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
    <title>Перша база на Марсі</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Source Code Pro;
            font-weight: 300;
        }

        body {
            color: white;
            margin-top: -10px;
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;

            background: #121212;
            background: linear-gradient(
                135deg,
                #F1F1F1 25%,
                #FFFFFF 25%,
                #FFFFFF 50%,
                #F1F1F1 50%,
                #F1F1F1 75%,
                #FFFFFF 75%,
                #FFFFFF
            );
            background-size: 60px 60px;

            animation: move 16s linear infinite;
        }

        @keyframes move {
            0% {
                background-position: 0 0;
            }
            100% {
                background-position: 40px 40px;
            }
        }

        header {
            background: rgba(255, 255, 255, 0.50);
            box-shadow: 0 15px 25px 0 rgba(144, 144, 144, 0.25), 0 5px 15px 0 rgba(217, 217, 217, 0.25), 0 1px 5px 0 rgba(255, 255, 255, 0.12);
            display: flex;
            flex-direction: row;
            justify-content: space-between;
            align-items: center;
            border-radius: 0 0 15px 15px;
            padding: 0 15px 0 15px;
            height: 60px;
            width: 99%;
            transition: 0.25s;
        }

        header:hover {
            background: rgba(255, 255, 255, 0.75);
            transition: 0.25s;
        }

        header h1 {
            text-shadow: 0 5px 5px rgba(0, 0, 0, 0.25);
            font-weight: 400;
            font-size: 36px;
            color: #000;
        }

        nav {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-top: 10px;
        }

        nav button {
            cursor: pointer;
            padding: 10px;
            cursor: pointer;
            border-radius: 15px;
            box-shadow: 0 15px 25px 0 rgba(144, 144, 144, 0.25), 0 5px 15px 0 rgba(217, 217, 217, 0.25), 0 1px 5px 0 rgba(255, 255, 255, 0.5), 0 0 0 1px #fff;
            background: #fff;
            font-weight: 400;
            font-size: 12px;
            color: #000;
            text-shadow: 0 5px 5px rgba(0, 0, 0, 0.25);
            border: none;
            transition: 0.25s;
        }

        nav button:hover {
            transform: scale(1.05);
            border: 1px solid #00fbff;
            transition: 0.25s;
        }

        .container {
            width: 90%;
            margin: 20px auto;
        }

        .container h2 {
            font-weight: 400;
            font-size: 36px;
            color: #000;
            text-shadow: 0 5px 5px 0 rgba(0, 0, 0, 0.25);
        }

        .products {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            padding: 25px;
            background: rgba(255, 255, 255, 0.50);
            border-radius: 15px;
            transition: 0.25s;
        }

        .products:hover {
            background: rgba(255, 255, 255, 0.75);
            transition: 0.25s;
        }

        .card {
            background: #fff;
            box-shadow: 0 15px 25px 0 rgba(144, 144, 144, 0.25), 0 5px 15px 0 rgba(217, 217, 217, 0.25), 0 1px 5px 0 rgba(255, 255, 255, 0.12);
            border-radius: 10px;
            text-align: center;
            width: 175px;
            padding: 15px;
            transition: 0.25s;
        }

        .card:hover {
            border: 2px solid #ff9200;
            border-radius: 15px;
            transform: scale(1.03);
            box-shadow: 0 15px 35px 1px rgba(144, 144, 144, 0.25), 0 5px 25px 1px rgba(217, 217, 217, 0.25), 0 1px 15px 1px rgba(255, 255, 255, 0.12), 0 0 0 2px #fff;
            background: #fff;
            transition: 0.25s;
        }

        .card img {
            width: 150px;
            object-fit: cover;
            border-radius: 10px;
        }

        .card h3 {
            font-weight: 300;
            font-size: 18px;
            color: #000;
            text-shadow: 0 5px 5px rgba(0, 0, 0, 0.25);
            height: 50px;
        }

        .card p {
            position: relative;
            color: #fff;
            top: -150px;
            font-weight: 400;
            text-shadow: 0 5px 5px rgba(0, 0, 0, 0.25);
            transition: 0.25s;
        }

        .card button {
            margin-top: 10px;
            padding: 10px;
            cursor: pointer;
            border-radius: 15px;
            box-shadow: 0 15px 25px 0 rgba(144, 144, 144, 0.25), 0 5px 15px 0 rgba(217, 217, 217, 0.25), 0 1px 5px 0 rgba(255, 255, 255, 0.5), 0 0 0 1px #fff;
            background: #fff;
            font-weight: 400;
            font-size: 12px;
            color: #000;
            text-shadow: 0 5px 5px rgba(0, 0, 0, 0.25);
            border: none;
            transition: 0.25s;
        }

        .card button:hover {
            transform: scale(1.05);

            border: 1px solid #00ff04;
            transition: 0.25s;
        }

        .modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.7);
            display: none;
            justify-content: center;
            align-items: center;
        }

        .modal-content {
            border-radius: 15px;
            box-shadow: 0 0 5px 5px rgba(255, 255, 255, 0.5), 0 0 15px 15px rgba(217, 217, 217, 0.25), 0 0 25px 25px rgba(144, 144, 144, 0.25);
            background: #fff;
            padding: 20px;
            width: 400px;
        }

        .modal-content img {
            width: 100%;
            height: 200px;
            object-fit: cover;
            margin-bottom: 10px;
        }

        .modal-content input {
            width: 100%;
            padding: 10px;
            margin-top: 10px;
        }

        .modal-content button {
            margin-top: 10px;
            padding: 10px;
            width: 100%;
        }

        .cart {
            margin-top: 30px;
            background: rgba(255, 255, 255, 0.50);
            padding: 20px;
            border-radius: 10px;
            transition: 0.25s;
        }

        .cart:hover {
            background: rgba(255, 255, 255, 0.75);
            transition: 0.25s;
        }

        #cartItems li {
            font-weight: 400;
            font-size: 18px;
            color: #000;
            text-shadow: 0 5px 5px rgba(0, 0, 0, 0.25);
        }

        footer {
            margin-top: 50px;
            padding: 20px;
            text-align: center;
            background: rgba(255, 255, 255, 0.50);
            border-radius: 15px 15px 0 0;
            width: 99%;
            box-shadow: 0 -15px 25px 0 rgba(144, 144, 144, 0.25), 0 -5px 15px 0 rgba(217, 217, 217, 0.25), 0 -1px 5px 0 rgba(255, 255, 255, 0.12);
            transition: 0.25s;
        }

        .hidden {
            display: none;
        }
    </style>
</head>
<body>
        <div id="stars"></div>
        <div id="stars2"></div>
        <div id="stars3"></div>
        <div></div>
    <header>
        <h1>Магазин рослин із марсіанських теплиць</h1>

        <nav>
        <button onclick="showLogin()">Увійти</button>
        <button onclick="showRegister()">Створити акаунт</button>
        </nav>
    </header>

    <div class="container">

        <h2>Наші товари</h2>

        <div class="products" id="products"></div>

        <div class="cart">
            <h2>Кошик</h2>
            <ul id="cartItems"></ul>
        </div>

    </div>

  <!-- МОДАЛЬНЕ ВІКНО ТОВАРУ -->
    <div class="modal" id="productModal">
        <div class="modal-content">
            <h2 id="modalTitle"></h2>

            <img id="modalImage" src="" alt="">

            <p id="modalDescription"></p>

            <h3 id="modalPrice"></h3>

            <input type="text" id="nameInput" placeholder="Ваше ім'я">
            <input type="text" id="addressInput" placeholder="Адреса доставки">

            <button onclick="addToCart()">Додати в кошик</button>
            <button onclick="buyNow()">Оплатити товар</button>
            <button onclick="closeModal()">Закрити</button>
        </div>
    </div>

    <script>
    // ====== ЗМІННІ ======

    let loggedIn = false;

    let cart = [];

    let selectedProduct = null;

    // ====== МАСИВ ТОВАРІВ ======

    const products = [
      {
        id: 1,
        name: "Марсіанська картопля",
        price: 120,
        description: "Стійка до холоду та низького тиску.",
        image: "https://images.unsplash.com/photo-1518977676601-b53f82aba655"
      },

      {
        id: 2,
        name: "Насіння червоних томатів",
        price: 90,
        description: "Вирощено в теплицях бази Olympus.",
        image: "https://images.unsplash.com/photo-1546094096-0df4bcaaa337"
      },

      {
        id: 3,
        name: "Паростки салату",
        price: 60,
        description: "Швидко ростуть навіть на Марсі.",
        image: "https://images.unsplash.com/photo-1490645935967-10de6ba17061"
      }
    ];

    // ====== ВІДОБРАЖЕННЯ ТОВАРІВ ======

    const productsContainer = document.getElementById("products");

    function renderProducts() {

      productsContainer.innerHTML = "";

      products.forEach(product => {

        productsContainer.innerHTML += `
          <div class="card">

            <img src="${product.image}" alt="${product.name}">

            <h3>${product.name}</h3>

            <p>${product.price} марсиків $</p>

            <button onclick="openModal(${product.id})">
              Придбати
            </button>

          </div>
        `;

      });

    }

    renderProducts();

    // ====== РЕЄСТРАЦІЯ / ВХІД ======

    function showLogin() {

      const login = prompt("Введіть ім'я користувача");

      const password = prompt("Введіть пароль");

      if(login && password) {

        loggedIn = true;

        alert("Вхід успішний!");

      }

    }

    function showRegister() {

      const login = prompt("Створіть логін");

      const password = prompt("Створіть пароль");

      if(login && password) {

        loggedIn = true;

        alert("Акаунт створено!");

      }

    }

    // ====== ВІДКРИТТЯ МОДАЛЬНОГО ВІКНА ======

    function openModal(id) {

      if(!loggedIn) {

        alert("Спочатку увійдіть або створіть акаунт!");

        return;

      }

      selectedProduct = products.find(product => product.id === id);

      document.getElementById("modalTitle").innerText = selectedProduct.name;

      document.getElementById("modalImage").src = selectedProduct.image;

      document.getElementById("modalDescription").innerText = selectedProduct.description;

      document.getElementById("modalPrice").innerText =
        selectedProduct.price + " марсиків";

      document.getElementById("productModal").style.display = "flex";

    }

    // ====== ЗАКРИТТЯ ВІКНА ======

    function closeModal() {

      document.getElementById("productModal").style.display = "none";

    }

    // ====== ДОДАТИ В КОШИК ======

    function addToCart() {

      const name = document.getElementById("nameInput").value;

      const address = document.getElementById("addressInput").value;

      if(name === "" || address === "") {

        alert("Заповніть усі поля!");

        return;

      }

      cart.push(selectedProduct);

      renderCart();

      alert("Товар додано в кошик!");

      closeModal();

    }

    // ====== ВІДОБРАЖЕННЯ КОШИКА ======

    function renderCart() {

      const cartItems = document.getElementById("cartItems");

      cartItems.innerHTML = "";

      cart.forEach(item => {

        cartItems.innerHTML += `
          <li>
            ${item.name} - ${item.price} марсиків
          </li>
        `;

      });

    }

    // ====== ОПЛАТА ======

    function buyNow() {

      const name = document.getElementById("nameInput").value;

      const address = document.getElementById("addressInput").value;

      if(name === "" || address === "") {

        alert("Заповніть усі поля!");

        return;

      }

      alert("Товар оплачено!");

      closeModal();

    }

    </script>

    <footer>
    <!-- Підвал сайту -->
    </footer>

</body>
</html>
